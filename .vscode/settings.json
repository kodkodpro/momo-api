{
  "tailwindCSS.includeLanguages": {
    "ruby": "html",
    "erb": "html"
  },
  "tailwindCSS.experimental.configFile": "app/assets/tailwind/application.css",
  "tailwindCSS.experimental.classRegex": [
    ["[\"']?class[\"']?:\\s*\\[([^\\]]*)\\]", "[\"']([^\"']*)[\"']"],
    ["[\"']?class[\"']?:\\s*[\"']([^\"']*)[\"']"]
  ],
  "files.exclude": {
    "**/sorbet/cache": true,
    "**/sorbet/rbi/annotations": true,
    "**/sorbet/rbi/dsl": true,
    "**/sorbet/rbi/gems": true,
    "**/sorbet/rbi/shims": true
  },
}
