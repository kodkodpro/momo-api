# Class methods that could conflict
#
# pkg:gem/operandi#lib/operandi/constants.rb:45
Operandi::ReservedNames::CLASS_METHODS = T.let(T.unsafe(nil), Array)

# Ruby reserved words and common Object methods
#
# pkg:gem/operandi#lib/operandi/constants.rb:77
Operandi::ReservedNames::RUBY_RESERVED = T.let(T.unsafe(nil), Array)

