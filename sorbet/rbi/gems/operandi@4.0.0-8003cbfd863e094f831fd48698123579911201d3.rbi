# Raised when a name is invalid (e.g., not a Symbol).
#
# pkg:gem/operandi#lib/operandi/exceptions.rb:14
class Operandi::InvalidNameError < ::Operandi::Error; end

# Represents a single error or warning message.
#
# @example Creating a message
#   message = Message.new(:name, "can't be blank", break: true)
#   message.key    # => :name
#   message.text   # => "can't be blank"
#   message.break? # => true
#
# pkg:gem/operandi#lib/operandi/message.rb:11
class Operandi::Message
  # Create a new message.
  #
  # @option opts
  # @option opts
  # @param key [Symbol] the key/field this message belongs to
  # @param opts [Hash] additional options
  # @param text [String] the message text
  # @return [Message] a new instance of Message
  #
  # pkg:gem/operandi#lib/operandi/message.rb:25
  def initialize(key, text, opts = T.unsafe(nil)); end

  # Check if this message should stop step execution.
  #
  # @return [Boolean] true if break option was set
  #
  # pkg:gem/operandi#lib/operandi/message.rb:34
  def break?; end

  # @return [Symbol] the key/field this message belongs to
  #
  # pkg:gem/operandi#lib/operandi/message.rb:13
  def key; end

  # Check if this message should trigger a transaction rollback.
  #
  # @return [Boolean] true if rollback option was set
  #
  # pkg:gem/operandi#lib/operandi/message.rb:41
  def rollback?; end

  # @return [String] the message text
  #
  # pkg:gem/operandi#lib/operandi/message.rb:16
  def text; end

  # Return the message text.
  #
