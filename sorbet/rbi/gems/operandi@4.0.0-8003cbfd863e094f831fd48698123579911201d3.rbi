# Configuration class for Operandi global settings.
#
# @example Accessing configuration
#   Operandi.config.require_arg_type # => true
# @example Modifying configuration
#   Operandi.config.use_transactions = false
#
# pkg:gem/operandi#lib/operandi/config.rb:35
class Operandi::Config
  # Initialize configuration with default values.
  #
  # @return [Config] a new instance of Config
  #
  # pkg:gem/operandi#lib/operandi/config.rb:110
  def initialize; end

  # @return [Boolean] whether to stop executing steps when an error is added
  #
  # pkg:gem/operandi#lib/operandi/config.rb:49
  def break_on_error; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def break_on_error=(value); end

  # @return [Boolean] whether to stop executing steps when a warning is added
  #
  # pkg:gem/operandi#lib/operandi/config.rb:61
  def break_on_warning; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def break_on_warning=(value); end

  # @return [Boolean] whether to copy errors to parent service in chain
  #
  # pkg:gem/operandi#lib/operandi/config.rb:46
  def load_errors; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def load_errors=(value); end

  # @return [Boolean] whether to copy warnings to parent service in chain
  #
  # pkg:gem/operandi#lib/operandi/config.rb:58
  def load_warnings; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def load_warnings=(value); end

  # Merge configuration with additional options.
  #
  # @param config [Hash] options to merge
  # @return [Hash] merged configuration hash
  #
  # pkg:gem/operandi#lib/operandi/config.rb:138
  def merge(config); end

  # @return [Boolean] whether to raise Operandi::Error when service fails
  #
  # pkg:gem/operandi#lib/operandi/config.rb:52
  def raise_on_error; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def raise_on_error=(value); end

  # @return [Boolean] whether to raise Operandi::Error when service has warnings
  #
  # pkg:gem/operandi#lib/operandi/config.rb:64
  def raise_on_warning; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def raise_on_warning=(value); end

  # @return [Boolean] whether arguments must have a type specified
  #
  # pkg:gem/operandi#lib/operandi/config.rb:37
  def require_arg_type; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def require_arg_type=(value); end

  # @return [Boolean] whether outputs must have a type specified
  #
  # pkg:gem/operandi#lib/operandi/config.rb:40
  def require_output_type; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def require_output_type=(value); end

  # Convenience setter for backward compatibility.
  # Sets both require_arg_type and require_output_type.
  #
  # @param value [Boolean] whether to require types for arguments and outputs
  # @return [void]
  #
  # pkg:gem/operandi#lib/operandi/config.rb:104
  def require_type=(value); end

  # Reset all configuration options to their default values.
  #
  # @return [void]
  #
  # pkg:gem/operandi#lib/operandi/config.rb:117
  def reset_to_defaults!; end

  # @return [Boolean] whether to rollback the transaction when an error is added
  #
  # pkg:gem/operandi#lib/operandi/config.rb:55
  def rollback_on_error; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def rollback_on_error=(value); end

  # @return [Boolean] whether to rollback the transaction when a warning is added
  #
  # pkg:gem/operandi#lib/operandi/config.rb:67
  def rollback_on_warning; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def rollback_on_warning=(value); end

  # @return [Hash{String => String}] custom type mappings for Ruby LSP addon.
  #   Maps custom types to Ruby types for hover/completion.
  #   @example { "CustomTypes::UUID" => "String", "CustomTypes::Money" => "BigDecimal" }
  #
  # pkg:gem/operandi#lib/operandi/config.rb:72
  def ruby_lsp_type_mappings; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def ruby_lsp_type_mappings=(value); end

  # Convert configuration to a hash.
  #
  # @return [Hash{Symbol => Object}] all configuration options as a hash
  #
  # pkg:gem/operandi#lib/operandi/config.rb:128
  def to_h; end

  # @return [Boolean] whether to wrap service execution in a database transaction
  #
  # pkg:gem/operandi#lib/operandi/config.rb:43
  def use_transactions; end

  # pkg:gem/operandi#lib/operandi/config.rb:93
  def use_transactions=(value); end
end

