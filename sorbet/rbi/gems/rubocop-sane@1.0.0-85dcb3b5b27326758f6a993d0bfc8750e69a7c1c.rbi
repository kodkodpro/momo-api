#   end
#
#   # bad
#   foo = case bar
#   when :a then 1
#   when :b then 2
#   end
#
#   # good - assignment inside condition
#   if condition
#   foo = 1
#   else
#   foo = 2
#   end
#
#   # good - ternary operators are allowed
#   foo = condition ? 1 : 2
#
#   # good - multiline ternary operators are allowed
#   foo = condition
