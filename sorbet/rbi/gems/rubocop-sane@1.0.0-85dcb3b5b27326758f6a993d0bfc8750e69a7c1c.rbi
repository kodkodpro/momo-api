  # pkg:gem/rubocop-sane#lib/rubocop/cop/sane/no_method_call_after_end.rb:51
  def on_send(node); end

  private

  # pkg:gem/rubocop-sane#lib/rubocop/cop/sane/no_method_call_after_end.rb:61
  def check_method_call_after_end(node); end

  # @return [Boolean]
  #
  # pkg:gem/rubocop-sane#lib/rubocop/cop/sane/no_method_call_after_end.rb:69
  def ends_with_end_keyword?(node); end
end

