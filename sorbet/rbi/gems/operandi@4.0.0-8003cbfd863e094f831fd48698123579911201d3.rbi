  def each(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/operandi#lib/operandi/messages.rb:39
  def each_with_index(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/operandi#lib/operandi/messages.rb:39
